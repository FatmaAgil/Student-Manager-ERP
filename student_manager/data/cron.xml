<odoo>

    <record id="ir_cron_check_students" model="ir.cron">
        <field name="name">Check Students Without Enrollments</field>

        <field name="model_id" ref="model_student_student" />
        <field name="state">code</field>
        <field name="code">model.check_students_without_enrollments()</field>

        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>

        <field name="active">True</field>
    </record>

</odoo>