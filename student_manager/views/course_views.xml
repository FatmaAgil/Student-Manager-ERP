<odoo>

    <!-- LIST VIEW -->
    <record id="view_course_list" model="ir.ui.view">
        <field name="name">course.list</field>
        <field name="model">student.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="total_enrollments" />
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_course_form" model="ir.ui.view">
        <field name="name">course.form</field>
        <field name="model">student.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="total_enrollments" readonly="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 🔥 KANBAN VIEW -->
    <record id="view_course_kanban" model="ir.ui.view">
        <field name="name">course.kanban</field>
        <field name="model">student.course</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">

                            <div class="o_kanban_card">
                                <strong>
                                    <field name="name" />
                                </strong>

                                <div> Enrollments: <field name="total_enrollments" />
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">student.course</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_course"
        name="Courses"
        parent="menu_student_root"
        action="action_course" />

</odoo>