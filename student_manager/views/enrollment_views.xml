<odoo>

    <!-- ENROLLMENT TREE VIEW -->
    <record id="view_enrollment_tree" model="ir.ui.view">
        <field name="name">enrollment.tree</field>
        <field name="model">student.enrollment</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id" />
                <field name="course_id" />
                <field name="grade" />
                <field name="status" />
                <field name="date" />
            </list>
        </field>
    </record>

    <!-- ENROLLMENT FORM VIEW -->
    <record id="view_enrollment_form" model="ir.ui.view">
        <field name="name">enrollment.form</field>
        <field name="model">student.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="student_id" />
                        <field name="course_id" />
                        <field name="grade" />
                        <field name="status" readonly="1" />
                        <field name="date" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_enrollment" model="ir.actions.act_window">
        <field name="name">Enrollments</field>
        <field name="res_model">student.enrollment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ENROLLMENT MENU -->
    <menuitem id="menu_enrollment"
        name="Enrollments"
        parent="menu_student_root"
        action="action_enrollment" />

</odoo>